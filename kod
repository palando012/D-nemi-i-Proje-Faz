# 5. STREAMLIT KULLANICI ARAYÜZÜ (UI)
# ==========================================

st.set_page_config(page_title="Cinsiyet Sınıflandırma", layout="wide")
st.title("🎙️ Ses İşareti Analizi ve Kural Tabanlı Sınıflandırma")

tab_demo, tab_dataset = st.tabs(["Canlı Demo", "Veri Seti Analizi ve Raporlama"])

with tab_demo:
    uploaded_file = st.file_uploader("Analiz edilecek .wav dosyasını yükleyin", type=['wav'])
    if uploaded_file is not None:
        temp_path = "temp_audio.wav"
        with open(temp_path, "wb") as f:
            f.write(uploaded_file.getbuffer())
        st.audio(temp_path, format='audio/wav')

        extracted_data, msg = extract_features(temp_path)
        if extracted_data:
            features, voiced_frames, sr = extracted_data
            f0_val = features['Ortalama_F0']
            prediction = classify_gender(f0_val)

            c1, c2 = st.columns(2)
            c1.metric("Tahmin Edilen Sınıf", prediction)
            c2.metric("Hesaplanan Ortalama F0", f"{f0_val:.2f} Hz")

            mid_idx = len(voiced_frames) // 2
            fig = plot_signals(voiced_frames[mid_idx], sr)
            st.pyplot(fig)
        else:
            st.error(f"Analiz Başarısız: {msg}")

        if os.path.exists(temp_path): os.remove(temp_path)

with tab_dataset:
    if st.button("Veri Setini Çalıştır ve Raporla", type="primary"):
        df_results, skipped, message = process_entire_dataset()

        # Hata Takip Ekranı (EĞER DOSYA OKUNAMADIYSA BURADA GÖZÜKECEK)
        if skipped:
            with st.expander(f"⚠️ Atlanan / İşlenemeyen Dosyalar ({len(skipped)} adet)", expanded=True):
                st.warning(
                    "Aşağıdaki dosyalar Excel'de var ancak analiz edilemedi. Sebeplerini tablodan inceleyebilirsiniz.")
                st.dataframe(pd.DataFrame(skipped), use_container_width=True)

        if df_results is not None and not df_results.empty:
            st.success(f"{message} (Başarıyla işlenen dosya sayısı: {len(df_results)})")

            stats = df_results.groupby('Gercek_Sinif').agg(
                Örnek_Sayısı=('F0', 'count'),
                Ortalama_F0=('F0', 'mean'),
                Standart_Sapma=('F0', 'std'),
                Basari_Yuzdesi=('Dogru_Mu', lambda x: (x.sum() / len(x)) * 100)
            ).reset_index()

            stats.columns = ['Sınıf', 'Örnek Sayısı', 'Ortalama F0 (Hz)', 'Standart Sapma', 'Başarı (%)']
            stats['Ortalama F0 (Hz)'] = stats['Ortalama F0 (Hz)'].round(2)
            stats['Standart Sapma'] = stats['Standart Sapma'].round(2)
            stats['Başarı (%)'] = stats['Başarı (%)'].round(2).astype(str) + " %"

            st.subheader("İstatistiksel Bulgular")
            st.dataframe(stats, use_container_width=True)

            st.subheader("Hata Analizi: Karışıklık Matrisi")
            labels = ['Erkek', 'Kadın', 'Çocuk']
            y_true = df_results['Gercek_Sinif'].tolist()
            y_pred = df_results['Tahmin_Sinif'].tolist()
            cm = confusion_matrix(y_true, y_pred, labels=labels)

            fig, ax = plt.subplots(figsize=(6, 4))
            sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', xticklabels=labels, yticklabels=labels, ax=ax)
            ax.set_ylabel('Gerçek Sınıf')
            ax.set_xlabel('Sistem Tahmini')
            st.pyplot(fig)
